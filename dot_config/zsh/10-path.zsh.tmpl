# ============================================
# PATH 配置
# 自动生成 - 请勿直接编辑此文件
# ============================================

# 添加到 PATH 的函数（避免重复）
add_to_path() {
    if [ -d "$1" ] && [[ ":$PATH:" != *":$1:"* ]]; then
        export PATH="$1:$PATH"
    fi
}

# ============================================
# 用户本地路径（优先级最高）
# ============================================

add_to_path "$HOME/.local/bin"
add_to_path "$HOME/bin"

# ============================================
# 开发工具路径
# ============================================

# Rust/Cargo
add_to_path "$HOME/.cargo/bin"

# Go
add_to_path "$HOME/go/bin"

# Bun
add_to_path "$HOME/.bun/bin"

# Python (pipx)
add_to_path "$HOME/.local/pipx/bin"

# ============================================
# 系统特定路径
# ============================================

{{- if .isArch }}
# Arch Linux 特定路径
add_to_path "/usr/local/sbin"
add_to_path "/usr/local/bin"
{{- end }}

{{- if .isMac }}
# macOS 特定路径
add_to_path "/opt/homebrew/bin"
add_to_path "/opt/homebrew/sbin"
add_to_path "/usr/local/bin"
add_to_path "/usr/local/sbin"

# macOS Python
add_to_path "$HOME/Library/Python/3.11/bin"
add_to_path "$HOME/Library/Python/3.12/bin"
{{- end }}

{{- if .isWSL }}
# WSL 特定路径
# Windows 路径（可选，根据需要取消注释）
# add_to_path "/mnt/c/Windows/System32"
{{- end }}

# ============================================
# 项目特定路径（如果存在）
# ============================================

add_to_path "$HOME/projects/scripts"

# ============================================
# 库路径
# ============================================

{{- if .isMac }}
export DYLD_LIBRARY_PATH="/opt/homebrew/lib:${DYLD_LIBRARY_PATH:-}"
{{- else }}
export LD_LIBRARY_PATH="/usr/local/lib:${LD_LIBRARY_PATH:-}"
{{- end }}

# ============================================
# Man 路径
# ============================================

{{- if .isMac }}
export MANPATH="/opt/homebrew/share/man:${MANPATH:-}"
{{- end }}

# 清理函数
unset -f add_to_path
