# ============================================
# 数据库快捷操作
# ============================================

# SQLite 数据库查看
view-db() {
    if [ -z "$1" ]; then
        echo "Usage: view-db <database.db>"
        return 1
    fi
    
    if [ -f "$1" ]; then
        sqlite3 "$1"
    else
        echo "数据库文件不存在: $1"
    fi
}

