# ============================================
# 快速备份
# ============================================

# 备份所有项目代码
backup-projects() {
    local backup_dir="$HOME/backups/projects-$(date +%Y%m%d)"
    mkdir -p "$backup_dir"
    
    echo "📦 备份所有项目到: $backup_dir"
    
    for dir in $PROJECTS_DIR/*/; do
        local project_name=$(basename "$dir")
        echo "备份: $project_name"
        
        tar -czf "$backup_dir/$project_name.tar.gz" \
            -C "$PROJECTS_DIR" \
            --exclude 'node_modules' \
            --exclude '.venv' \
            --exclude '__pycache__' \
            "$project_name"
    done
    
    echo "✅ 备份完成: $backup_dir"
}
