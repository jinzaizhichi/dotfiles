# 期权交易开发环境
dev-options() {
    echo "📊 期权交易开发环境"
    
    # 进入项目目录
    cdopt
    
    # 激活 Python 环境
    if [ -f .venv/bin/activate ]; then
        source .venv/bin/activate
        echo "✅ Python 虚拟环境已激活"
    fi
    
    # 设置环境变量（如果有 .env 文件）
    if [ -f .env ]; then
        export $(cat .env | grep -v '^#' | xargs)
        echo "✅ 环境变量已加载"
    fi
    
    echo "💡 使用 start-options-tracker 启动服务"
}

