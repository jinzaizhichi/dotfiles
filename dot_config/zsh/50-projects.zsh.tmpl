# SSH 到 VPS
ssh-vps() {
    ssh root@91.230.73.42
}

# 同步项目到 VPS
sync-to-vps() {
    if [ -z "$1" ]; then
        echo "Usage: sync-to-vps <project-name>"
        echo "Available: tv-chart, options-tracker, tg-bot, wechat-account"
        return 1
    fi
    
    local project="$1"
    local local_path="$PROJECTS_DIR/$project"
    local remote_path="/opt/$project"
    
    if [ ! -d "$local_path" ]; then
        echo "项目不存在: $project"
        return 1
    fi
    
    echo "📤 同步 $project 到 VPS..."
    rsync -avz --progress \
        --exclude 'node_modules' \
        --exclude '.venv' \
        --exclude '__pycache__' \
        --exclude '.git' \
        "$local_path/" \
        "root@91.230.73.42:$remote_path/"
    
    echo "✅ 同步完成"
}

