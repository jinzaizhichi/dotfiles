export PROJECTS_DIR="$HOME/projects"

# ============================================
# 项目启动函数
# ============================================

# tv-chart - TradingView 图表项目
start-tv-chart() {
    cd ~/projects/tv-chart
    echo "🚀 Starting tv-chart development server..."
    npm run dev
}

# options-tracker - 期权追踪器
start-options-tracker() {
    cd ~/projects/options-tracker
    echo "🚀 Starting options tracker..."
    
    # 激活虚拟环境（如果存在）
    if [ -f .venv/bin/activate ]; then
        source .venv/bin/activate
    fi
    
    # 启动服务
    if [ -f app.py ]; then
        python app.py
    elif [ -f main.py ]; then
        python main.py
    else
        echo "未找到启动文件"
    fi
}

# telegram-bot - Telegram 机器人
start-tg-bot() {
    cd ~/projects/tg-bot
    echo "🚀 Starting Telegram bot..."
    
    if [ -f .venv/bin/activate ]; then
        source .venv/bin/activate
    fi
    
    python bot.py
}

# wechat-account - 微信公众号
start-wx-account() {
    cd ~/projects/wechat-account
    echo "🚀 Starting WeChat account service..."
    
    if [ -f .venv/bin/activate ]; then
        source .venv/bin/activate
    fi
    
    flask run --host=0.0.0.0 --port=5000
}

# jinzaizhichi.cn - 淘宝联盟网站
start-taobao-site() {
    cd ~/projects/jinzaizhichi.cn
    echo "🚀 Starting Taobao affiliate site..."
    
    # 根据项目类型启动
    if [ -f package.json ]; then
        npm run dev
    elif [ -f app.py ]; then
        if [ -f .venv/bin/activate ]; then
            source .venv/bin/activate
        fi
        python app.py
    fi
}

# ============================================
# 项目状态检查
# ============================================

# 检查所有项目的 Git 状态
check-all-projects() {
    echo "📊 检查所有项目状态...\n"
    
    local projects=(
        "tv-chart"
        "options-tracker"
        "tg-bot"
        "wechat-account"
        "jinzaizhichi.cn"
    )
    
    for project in "${projects[@]}"; do
        local dir="$PROJECTS_DIR/$project"
        if [ -d "$dir" ]; then
            echo "📁 $project:"
            cd "$dir"
            
            if [ -d .git ]; then
                git status --short
                echo ""
            else
                echo "  ⚠️  不是 Git 仓库\n"
            fi
        else
            echo "📁 $project: ❌ 目录不存在\n"
        fi
    done
    
    cd - > /dev/null
}

# 拉取所有项目
pull-all-projects() {
    echo "📥 拉取所有项目...\n"
    
    for dir in $PROJECTS_DIR/*/; do
        if [ -d "$dir/.git" ]; then
            echo "📥 $(basename $dir):"
            (cd "$dir" && git pull)
            echo ""
        fi
    done
}

