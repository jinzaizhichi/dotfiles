# ============================================
# ~/.zshrc - Zsh 配置入口
# 使用 Chezmoi 管理 - 请勿直接编辑
# 编辑方式: chezmoi edit ~/.zshrc
# ============================================
#
# 系统: {{ .chezmoi.os }}/{{ .chezmoi.osRelease.id | default "unknown" }}
# 用户: {{ .name }}
#
# ============================================

# ============================================
# ============================================
# Powerlevel10k Instant Prompt（必须在任何输出之前）
# ============================================
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
export LANG=en_US.UTF-8
# ============================================
# Oh My Zsh 基础配置
# ============================================

# Oh My Zsh 路径
export ZSH="$HOME/.oh-my-zsh"

# 主题设置（p10k 在 40-tools.zsh 中从系统包加载覆盖）
ZSH_THEME="robbyrussell"

# 更新设置
zstyle ':omz:update' mode auto

# 插件（必须在 source oh-my-zsh.sh 之前设置）
plugins=(
    git
    zsh-autosuggestions
)

# 加载 Oh My Zsh
# 提前设置 LS_COLORS，绕过 WSL2 下 source <(dircolors) 的 /proc/self/fd 报错
[[ -z "$LS_COLORS" ]] && eval $(dircolors -b)
unalias colors 2>/dev/null  # 防止自定义 colors alias 干扰 OMZ 初始化
source $ZSH/oh-my-zsh.sh

# ============================================
# 模块化配置加载
# ============================================

# Zsh 配置目录
ZSH_CONFIG_DIR="$HOME/.config/zsh"

# 按顺序加载配置模块
if [ -d "$ZSH_CONFIG_DIR" ]; then
    # 00-env.zsh: 环境变量
    [ -f "$ZSH_CONFIG_DIR/00-env.zsh" ] && source "$ZSH_CONFIG_DIR/00-env.zsh"
    
    # 10-path.zsh: PATH 配置
    [ -f "$ZSH_CONFIG_DIR/10-path.zsh" ] && source "$ZSH_CONFIG_DIR/10-path.zsh"
    
    # 20-aliases.zsh: 别名
    [ -f "$ZSH_CONFIG_DIR/20-aliases.zsh" ] && source "$ZSH_CONFIG_DIR/20-aliases.zsh"
    
    # 30-functions.zsh: 自定义函数
    [ -f "$ZSH_CONFIG_DIR/30-functions.zsh" ] && source "$ZSH_CONFIG_DIR/30-functions.zsh"
    
    # 40-tools.zsh: 工具集成（fasd, atuin, p10k等）
    [ -f "$ZSH_CONFIG_DIR/40-tools.zsh" ] && source "$ZSH_CONFIG_DIR/40-tools.zsh"
    
    # 50-projects.zsh: 项目特定配置
    [ -f "$ZSH_CONFIG_DIR/50-projects.zsh" ] && source "$ZSH_CONFIG_DIR/50-projects.zsh"
    
    # 99-local.zsh: 本地配置（不提交到 Git）
    [ -f "$ZSH_CONFIG_DIR/99-local.zsh" ] && source "$ZSH_CONFIG_DIR/99-local.zsh"
fi

# ============================================
# 兼容性：加载旧的本地配置
# ============================================

[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# ============================================
# 欢迎信息
# ============================================

{{- if .isWSL }}
echo "🐧 WSL2 Arch Linux - Welcome {{ .name }}!"
{{- else if .isArch }}
echo "🐧 Arch Linux - Welcome {{ .name }}!"
{{- else if .isUbuntu }}
echo "🐧 Ubuntu - Welcome {{ .name }}!"
{{- else if .isMac }}
echo "🍎 macOS - Welcome {{ .name }}!"
{{- else }}
echo "👋 Welcome {{ .name }}!"
{{- end }}
typeset -g POWERLEVEL9K_INSTANT_PROMPT=off
# 提示可用的快捷命令
# echo "💡 Tips: cdtv | cdopt | gs | docker-cleanup | pyproject"
